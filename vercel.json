{
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/scrape-july",
      "schedule": "0 8 * * *"
    }
  ],
  "functions": {
    "api/scrape-july.js": {
      "maxDuration": 60,
      "memory": 512
    }
  }
}
